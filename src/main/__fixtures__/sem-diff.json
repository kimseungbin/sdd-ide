      "oldFilePath": null,
      "oldParentId": null,
      "beforeContent": "async function runNode(args: string[]): Promise<string> {\n  const { stdout } = await execFileAsync(process.execPath, args, {\n    env: { ...process.env, ELECTRON_RUN_AS_NODE: '1' },\n  })\n  return stdout.trim()\n}",
      "afterContent": "async function runNode(args: string[]): Promise<string> {\n  return run(process.execPath, args, {\n    env: { ...process.env, ELECTRON_RUN_AS_NODE: '1' },\n  })\n}",
