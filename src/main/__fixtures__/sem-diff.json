      "author": null,
      "structuralChange": false
    },
    {
      "entityId": "src/main/subprocess.ts::function::run",
      "changeType": "added",
      "entityType": "function",
      "entityName": "run",
      "startLine": 18,
      "endLine": 25,
      "oldStartLine": null,
      "oldEndLine": null,
      "oldEntityName": null,
      "filePath": "src/main/subprocess.ts",
      "oldFilePath": null,
      "oldParentId": null,
      "beforeContent": null,
      "afterContent": "async function run(cmd: string, args: string[], opts: RunOptions = {}): Promise<string> {\n  const { stdout } = await execFileAsync(cmd, args, {\n    cwd: opts.cwd,\n    env: opts.env ?? process.env,\n    maxBuffer: 32 * 1024 * 1024,\n  })\n  return stdout.trim()\n}",
      "commitSha": null,
      "author": null,
      "structuralChange": null
    },
