#!/bin/sh
# Pre-push gate (BL-003): the full test suite before code leaves the machine. Kept out of
# pre-commit so commits stay fast; still cheaper than waiting on CI to catch a red test.
set -e

printf '\033[36m▸ test\033[0m\n'
if ! npm run --silent test; then
  printf '\033[31m✗ pre-push failed: tests must pass before pushing.\033[0m\n'
  exit 1
fi
printf '\033[32m✓ pre-push passed\033[0m\n'
